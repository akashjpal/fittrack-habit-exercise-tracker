# ============================================
# FitTrack Server Environment Variables
# Copy this file to .env and fill in values
# ============================================

# Server
PORT=5000
NODE_ENV=development

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173,https://yourdomain.com

# InsForge Configuration
INSFORGE_BASE_URL=https://your-project.insforge.app
INSFORGE_ANON_KEY=your_insforge_anon_key_here
INSFORGE_SERVICE_KEY=your_insforge_service_key_here

# Groq AI (for AI features + voice transcription)
GROQ_API_KEY=your_groq_api_key_here
