# ============================================
# FitTrack Environment Variables
# Copy this file to .env and fill in values
# ============================================

# Server
PORT=5000
NODE_ENV=development

# InsForge Configuration
INSFORGE_BASE_URL=https://tvg89cmj.ap-southeast.insforge.app
INSFORGE_ANON_KEY=ik_3517a654c34b7c7492b3809c49b54e16
INSFORGE_SERVICE_KEY=your_insforge_service_key_here

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173,https://yourdomain.com

# Groq AI (for AI features + voice transcription)
GROQ_API_KEY=your_groq_api_key_here

# ============================================
# Vite Client Environment Variables
# Must be prefixed with VITE_ to be exposed to client
# ============================================

VITE_INSFORGE_BASE_URL=https://tvg89cmj.ap-southeast.insforge.app
VITE_INSFORGE_ANON_KEY=ik_3517a654c34b7c7492b3809c49b54e16
VITE_API_BASE_URL=http://localhost:5000
